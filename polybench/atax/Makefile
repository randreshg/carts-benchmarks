EXAMPLE_NAME := atax
SRC := atax.c
EXTRA_CFLAGS := -DM_PI=3.14159265358979323846
LDFLAGS := -lm -ldl

# Size configurations - can be overridden via command line
# LARGE (64-core): 23040 (360x64). EXTRALARGE (1920-worker): 46080 (24x1920). 4.0x LARGE
SMALL_CFLAGS ?= -DSMALL_DATASET
MEDIUM_CFLAGS ?= -DSTANDARD_DATASET
LARGE_CFLAGS ?= -DNX=16320 -DNY=16320 -DNREPS=50
EXTRALARGE_CFLAGS ?= -DNX=32640 -DNY=32640 -DNREPS=50

