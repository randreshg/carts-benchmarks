{
  "name": "gemm-v5-focused",
  "description": "Focused GEMM validation for 32-node distributed-db stability with matching baselines",
  "arts_config": "arts-4T.cfg",
  "setup_commands": [
    "carts update --force"
  ],
  "steps": [
    {
      "name": "strong-baseline-32n-4t",
      "benchmarks": ["polybench/gemm"],
      "nodes": "32",
      "threads": "4",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg",
      "timeout": 600
    },
    {
      "name": "strong-distributed-db-32n-4t",
      "benchmarks": ["polybench/gemm"],
      "nodes": "32",
      "threads": "4",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg",
      "compile_args": "--distributed-db",
      "timeout": 600
    },
    {
      "name": "n32-baseline-info-32t",
      "benchmarks": ["polybench/gemm"],
      "nodes": "32",
      "threads": "32",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg",
      "timeout": 600
    },
    {
      "name": "n32-distributed-db-info-32t",
      "benchmarks": ["polybench/gemm"],
      "nodes": "32",
      "threads": "32",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg",
      "compile_args": "--distributed-db",
      "timeout": 600
    },
    {
      "name": "n32-baseline-info-64t",
      "benchmarks": ["polybench/gemm"],
      "nodes": "32",
      "threads": "64",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg",
      "timeout": 600
    },
    {
      "name": "n32-distributed-db-info-64t",
      "benchmarks": ["polybench/gemm"],
      "nodes": "32",
      "threads": "64",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg",
      "compile_args": "--distributed-db",
      "timeout": 600
    }
  ]
}
