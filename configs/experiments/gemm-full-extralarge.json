{
  "name": "gemm-full-extralarge",
  "description": "GEMM validation: large single-node thread/perf/counter checks, then pure extralarge multinode timing sweep plus targeted instrumented multinode comparison",
  "steps": [
    {
      "name": "thread-sweep",
      "benchmarks": ["polybench/gemm"],
      "size": "large",
      "threads": "1,2,4,8,16,32,64",
      "nodes": "1",
      "debug": 0,
      "runs": 5,
      "perf": false
    },
    {
      "name": "perf-single-node",
      "benchmarks": ["polybench/gemm"],
      "size": "large",
      "threads": "64",
      "nodes": "1",
      "debug": 0,
      "runs": 5,
      "perf": true
    },
    {
      "name": "counters-single-node",
      "benchmarks": ["polybench/gemm"],
      "size": "large",
      "threads": "64",
      "nodes": "1",
      "debug": 0,
      "runs": 1,
      "perf": false,
      "profile": "profile-thread-edt.cfg"
    },
    {
      "name": "node-sweep-baseline",
      "benchmarks": ["polybench/gemm"],
      "size": "extralarge",
      "threads": "64",
      "nodes": "2,4,8,16,32",
      "debug": 0,
      "runs": 5,
      "perf": false
    },
    {
      "name": "node-sweep-distributed-db",
      "benchmarks": ["polybench/gemm"],
      "size": "extralarge",
      "threads": "64",
      "nodes": "2,4,8,16,32",
      "debug": 0,
      "runs": 5,
      "perf": false,
      "compile_args": "--distributed-db"
    },
    {
      "name": "multinode-overhead-baseline",
      "benchmarks": ["polybench/gemm"],
      "size": "extralarge",
      "threads": "64",
      "nodes": "8,32",
      "debug": 0,
      "runs": 1,
      "perf": false,
      "profile": "profile-overhead.cfg"
    },
    {
      "name": "multinode-overhead-distributed-db",
      "benchmarks": ["polybench/gemm"],
      "size": "extralarge",
      "threads": "64",
      "nodes": "8,32",
      "debug": 0,
      "runs": 1,
      "perf": false,
      "profile": "profile-overhead.cfg",
      "compile_args": "--distributed-db"
    }
  ]
}
