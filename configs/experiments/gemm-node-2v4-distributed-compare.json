{
  "name": "gemm-node-2v64-distributed-compare",
  "description": "GEMM single-node reference + multi-node strong-scaling + 64-node thread-sensitivity with and without --distributed-db",
  "steps": [
    {
      "name": "n1-64t-baseline",
      "benchmarks": ["polybench/gemm"],
      "nodes": "1",
      "threads": "64",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg"
    },
    {
      "name": "strong-baseline",
      "benchmarks": ["polybench/gemm"],
      "nodes": "2,4,8,16,32,64",
      "threads": "4",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg"
    },
    {
      "name": "strong-distributed-db",
      "benchmarks": ["polybench/gemm"],
      "nodes": "2,4,8,16,32,64",
      "threads": "4",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg",
      "compile_args": "--distributed-db"
    },
    {
      "name": "n64-thread-sweep-baseline",
      "benchmarks": ["polybench/gemm"],
      "nodes": "64",
      "threads": "2,4,8,16,32",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg"
    },
    {
      "name": "n64-thread-sweep-distributed-db",
      "benchmarks": ["polybench/gemm"],
      "nodes": "64",
      "threads": "2,4,8,16,32",
      "debug": 1,
      "runs": 1,
      "perf": false,
      "profile": "profile-workload.cfg",
      "compile_args": "--distributed-db"
    }
  ]
}
